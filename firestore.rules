rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Helper function to check if the incoming request is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to verify if the authenticated user has the 'admin' role.
    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Helper function to verify if a user document is owned by the requesting authenticated user
    function isOwner(uid) {
      return isAuthenticated() && request.auth.uid == uid;
    }

    // Helper: ensure the role field is not being changed (used in self-update guard)
    // A normal user can NEVER change their own role — only an admin can do that.
    function roleIsUnchanged() {
      return request.resource.data.role == resource.data.role;
    }

    // ==========================================
    // DATA FLOW DOCUMENTATION
    // ==========================================
    // Firebase Authentication stores:
    //   - email: <username>@meg.local  (synthetic, never shown to user)
    //   - password: hashed by Firebase Auth (NEVER written to Firestore)
    //
    // Firestore /users/{uid} document stores ONLY:
    //   - uid        : string  (Firebase Auth UID)
    //   - username   : string  (lowercase, 3-20 chars, a-z 0-9 _ -)
    //   - createdAt  : timestamp
    //   - role       : 'student' | 'admin'  (admin-only writes)
    //   + optional profile fields added on update (displayName, enrolment, etc.)
    // ==========================================

    // ==========================================
    // 1. RULES FOR USERS COLLECTION
    // ==========================================
    match /users/{uid} {
      
      // Allow reading a single profile document if owner or admin
      allow get: if isOwner(uid) || isAdmin();

      // Allow querying the users collection to check username uniqueness (e.g. limit 1)
      allow list: if request.query.limit == 1;
      
      // Creating a user document
      allow create: if isOwner(uid)
        // Prevent privilege escalation: new accounts must always start with the 'student' role.
        // The 'admin' role can only be granted by an existing admin after account creation.
        && request.resource.data.role == 'student'
        // Restrict initial document to exactly these 4 fields — no extra keys allowed
        && request.resource.data.keys().hasOnly([
             'uid', 'username', 'createdAt', 'role'
           ])
        // Verify key integrity and types
        && request.resource.data.uid == uid
        && request.resource.data.username is string
        // Ensure username is not an empty string
        && request.resource.data.username.size() > 0;

      // Updating a user document
      allow update: if
        // ── Case A: Admin update (can change role, add/remove fields, etc.) ──────────────────
        // IMPORTANT: Only admins can change the 'role' field. This is the sole
        // mechanism for granting or revoking admin privileges.
        isAdmin()
        && request.resource.data.keys().hasOnly([
             'uid', 'username', 'displayName', 'photoURL', 'provider',
             'emailVerified', 'createdAt', 'lastLogin', 'role', 'profileCompleted',
             'bio', 'university', 'course', 'semester', 'country',
             'bookmarks', 'progress', 'downloads', 'settings', 'lastVisitedResource',
             'enrolment', 'programme'
           ])
        ||
        // ── Case B: Owner self-update (CANNOT change role, uid, username, or createdAt) ─────
        // A normal user can update their own profile fields but is strictly
        // prohibited from changing their role, uid, username, or createdAt.
        (
          isOwner(uid)
          // ROLE PROTECTION: A user can NEVER change their own role.
          // Only an admin (Case A above) may modify the role field.
          && roleIsUnchanged()
          // Protect other immutable account metadata
          && request.resource.data.uid == resource.data.uid
          && request.resource.data.username == resource.data.username
          && request.resource.data.createdAt == resource.data.createdAt
          // Only allow known profile fields — block any arbitrary new keys
          && request.resource.data.keys().hasOnly([
              'uid', 'username', 'displayName', 'photoURL', 'provider',
              'emailVerified', 'createdAt', 'lastLogin', 'role', 'profileCompleted',
              'bio', 'university', 'course', 'semester', 'country',
              'bookmarks', 'progress', 'downloads', 'settings', 'lastVisitedResource',
              'enrolment', 'programme'
            ])
          // Validate types for optional fields if included in the update
          && (!('displayName' in request.resource.data) || request.resource.data.displayName is string)
          && (!('photoURL' in request.resource.data) || request.resource.data.photoURL is string)
          && (!('provider' in request.resource.data) || request.resource.data.provider is string)
          && (!('emailVerified' in request.resource.data) || request.resource.data.emailVerified is bool)
          && (!('profileCompleted' in request.resource.data) || request.resource.data.profileCompleted is bool)
          && (!('bio' in request.resource.data) || request.resource.data.bio is string)
          && (!('university' in request.resource.data) || request.resource.data.university is string)
          && (!('course' in request.resource.data) || request.resource.data.course is string)
          && (!('semester' in request.resource.data) || request.resource.data.semester is string)
          && (!('country' in request.resource.data) || request.resource.data.country is string)
          && (!('bookmarks' in request.resource.data) || request.resource.data.bookmarks is list)
          && (!('progress' in request.resource.data) || request.resource.data.progress is list)
          && (!('downloads' in request.resource.data) || request.resource.data.downloads is list)
          && (!('settings' in request.resource.data) || request.resource.data.settings is map)
          && (!('lastVisitedResource' in request.resource.data) || request.resource.data.lastVisitedResource is string)
          && (!('enrolment' in request.resource.data) || request.resource.data.enrolment is string)
          && (!('programme' in request.resource.data) || request.resource.data.programme is string)
        );

      // Deleting user profiles is completely forbidden
      allow delete: if false;

      // Notes subcollection
      match /notes/{noteId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }

      // Quizzes subcollection
      match /quizzes/{quizId} {
        allow read, write: if isOwner(uid) || isAdmin();
      }
    }

    // ==========================================
    // 2. RULES FOR RESOURCES COLLECTION
    // ==========================================
    match /resources/{resourceId} {
      
      // Read access control:
      // - Admins can read all resources (both published and drafts)
      // - Students/Guests can only read resource assets that are explicitly marked as published
      allow read: if isAdmin() || (resource.data.published == true);

      // Write access control:
      // - Only verified administrators are authorized to add, edit, or delete content resources
      allow create: if isAdmin()
        // Enforce document structure integrity: prevent writing arbitrary fields
        && request.resource.data.keys().hasOnly([
             'title', 'description', 'course', 'subject', 'type', 
             'semester', 'tags', 'fileUrl', 'thumbnail', 'createdBy', 
             'createdAt', 'updatedAt', 'published'
           ])
        // Validate required field type attributes
        && request.resource.data.title is string
        && request.resource.data.course is string
        && request.resource.data.subject is string
        && request.resource.data.type is string
        && request.resource.data.fileUrl is string
        && request.resource.data.published is bool
        // Validate optional field type attributes if supplied
        && (!('description' in request.resource.data) || request.resource.data.description is string)
        && (!('semester' in request.resource.data) || request.resource.data.semester is string)
        && (!('thumbnail' in request.resource.data) || request.resource.data.thumbnail is string)
        && (!('tags' in request.resource.data) || request.resource.data.tags is list);

      allow update: if isAdmin()
        // Prevent updates from introducing arbitrary fields
        && request.resource.data.keys().hasOnly([
             'title', 'description', 'course', 'subject', 'type', 
             'semester', 'tags', 'fileUrl', 'thumbnail', 'createdBy', 
             'createdAt', 'updatedAt', 'published'
           ])
        // Validate required field type attributes
        && request.resource.data.title is string
        && request.resource.data.course is string
        && request.resource.data.subject is string
        && request.resource.data.type is string
        && request.resource.data.fileUrl is string
        && request.resource.data.published is bool
        // Validate optional field type attributes if supplied
        && (!('description' in request.resource.data) || request.resource.data.description is string)
        && (!('semester' in request.resource.data) || request.resource.data.semester is string)
        && (!('thumbnail' in request.resource.data) || request.resource.data.thumbnail is string)
        && (!('tags' in request.resource.data) || request.resource.data.tags is list);

      allow delete: if isAdmin();
    }
  }
}
